{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-sonnet-4-20250514",
  "permissions": {
    "allow": [
      "Read(src/**/*.java)",
      "Read(src/**/*.yml)",
      "Read(src/**/*.yaml)",
      "Read(src/**/*.properties)",
      "Read(src/**/*.xml)",
      "Read(build.gradle)",
      "Read(settings.gradle)",
      "Read(gradle/**)",
      "Read(.opencode/**)",
      "Write(src/**/*.java)",
      "Write(src/**/*.xml)",
      "Write(src/**/*.yml)",
      "Write(src/**/*.yaml)",
      "Write(src/**/*.properties)",
      "Bash(gradlew *)",
      "Bash(gradlew.bat *)",
      "Bash(git *)",
      "Bash(docker *)",
      "Network(localhost:8080)",
      "Network(localhost:3306)",
      "Network(localhost:8848)"
    ],
    "defaultMode": "acceptEdits"
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },
  "includeGitInstructions": true
}
